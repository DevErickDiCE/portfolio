---
import { SERVICES } from "../config";
---

<section id="servicios" class="py-24 bg-gray-800">
    <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl font-bold mb-12 text-white">Qué hago</h2>

        <div class="space-y-6 text-lg md:text-xl font-mono text-gray-400">
            <div class="flex items-start">
                <span class="text-green-500 mr-4">_</span>
                <p>
                    <span class="text-white">Desarrollo web profesional</span> con
                    <span class="text-green-400">WordPress</span> (<span
                        class="text-white">Gutenberg</span
                    > y <span class="text-white">Elementor</span>) y
                    <span class="text-green-400">Astro</span> (rápidas, claras y preparadas
                    para crecer)
                </p>
            </div>

            <div class="flex items-start">
                <span class="text-green-500 mr-4">_</span>
                <p>
                    <span class="text-white"
                        >Implementación de automatización y lógica backend</span
                    > con
                    <span class="text-green-400">Python</span>, <span
                        class="text-green-400">SQL</span
                    > y <span class="text-green-400">n8n</span>
                </p>
            </div>

            <div class="flex items-start">
                <span class="text-green-500 mr-4">_</span>
                <p>
                    <span class="text-white">Integración de herramientas</span>,
                    despliegue y mantenimiento continuo
                </p>
            </div>
        </div>
    </div>
</section>
