---
import { SITE_CONFIG } from "../config";
---

<footer class="bg-gray-950 pt-0 pb-8">
    <div class="container mx-auto px-6 flex flex-col items-center gap-6">
        <p class="text-sm text-gray-500 font-mono tracking-wide">
            Erick Piñerua
        </p>
        <p class="text-xs text-gray-600 font-mono tracking-wider">
            Desarrollo web · Automatización · IA aplicada · Soporte técnico
        </p>

        <div class="text-xs text-gray-600">
            Madrid, España
        </div>

        <div
            class="flex items-center gap-8 text-white/90 font-medium text-lg tracking-wide"
        >
            <a
                href={`mailto:${SITE_CONFIG.email}`}
                class="hover:text-white transition-colors duration-300 border-b border-transparent hover:border-white/40 pb-0.5"
            >
                Email
            </a>
            <span class="text-white/20">/</span>
            <a
                href="https://www.linkedin.com/in/erick-pi%C3%B1erua/"
                class="hover:text-white transition-colors duration-300 border-b border-transparent hover:border-white/40 pb-0.5"
            >
                LinkedIn
            </a>
            <span class="text-white/20">/</span>
            <a
                href={`https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(SITE_CONFIG.whatsappMessage)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-white transition-colors duration-300 border-b border-transparent hover:border-white/40 pb-0.5"
            >
                WhatsApp
            </a>
        </div>

        <p
            class="text-gray-600/60 text-xs font-medium tracking-widest mt-4 uppercase"
        >
            &copy; {new Date().getFullYear()}
            {SITE_CONFIG.author} — Desarrollo web · Automatización · IA aplicada
        </p>
    </div>
</footer>
